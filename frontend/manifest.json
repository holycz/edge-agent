{
  "manifest_version": 3,
  "name": "移点通",
  "version": "1.0",
  "description": "陕西移动智能划词问答助手 - 润色、稽核、总结、AI对话",
  "permissions": ["contextMenus", "activeTab", "scripting", "storage", "sidePanel", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*", "sidepanel.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "打开 移点通"
  }
}